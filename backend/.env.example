# ============================================================
# backend/.env.example
# Copie para .env e preencha com seus dados reais
# ============================================================

# Servidor
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Banco de dados (Oracle)
DB_TYPE=oracle
DB_USER=seu_usuario
DB_PASS=sua_senha
DB_HOST=192.168.0.1/ORCL       # host:porta/SID  ou  host/ServiceName

# Se usar PostgreSQL, comente as linhas acima e use:
# DB_TYPE=postgres
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/banco

# Autenticacao JWT
JWT_SECRET=sua-chave-super-secreta-com-32-chars-ou-mais
JWT_EXPIRES=10h
